# Required: OpenRouter API key used by the AI chat sidebar.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Optional: secret used to sign session cookies (backend/app/auth.py).
# Defaults to a well-known dev value if unset, which is fine for local-only
# use. Set a real random value if this ever runs somewhere reachable by
# anyone other than you.
SESSION_SECRET=

# Optional: comma-separated username:password pairs allowed to sign in
# (backend/app/db.py). Each user gets their own boards. Passwords are kept
# only here, never stored in the database. Defaults to user:password.
SEED_USERS=user:password
